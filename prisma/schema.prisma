// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  // Relations to financial data
  wallets      Wallet[]
  categories   Category[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

// --- FINANCIAL MODELS ---

enum WalletType {
  CASH // Physical Wallet
  E_WALLET // QRIS, Gopay, OVO, Dana
  BANK // Savings, Debit, Credit Cards
  GOLD // Physical Gold or Digital Gold assets
}

model Wallet {
  id   String     @id @default(cuid())
  name String // e.g., "BCA Utama", "Gopay Pocket", "My Gold"
  type WalletType @default(CASH)

  // Use Decimal for money to avoid rounding issues (Rp millions can be large)
  balance Decimal @default(0) @db.Decimal(20, 2)

  // Only used if type is GOLD (tracked in grams)
  goldWeight Decimal? @default(0) @db.Decimal(10, 3)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum EntryType {
  INCOME
  OUTCOME
  TRANSFER // Moving money between your own wallets (e.g., Bank -> QRIS)
}

model Category {
  id    String  @id @default(cuid())
  name  String // e.g., "Food", "Salary", "Investment"
  icon  String // e.g., "Utensils", "Wallet", "TrendingUp" (Lucide icon names)
  color String? // Optional: hex code for UI branding (e.g., "#EF4444")

  userId String? // Optional: null for "System Default", or ID for "User Custom"
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@unique([name, userId])
  @@index([userId])
}

model Transaction {
  id         String  @id @default(cuid())
  userId     String
  walletId   String
  categoryId String? // Changed from String to Relation ID

  amount     Decimal  @db.Decimal(20, 2)
  gramAmount Decimal? @db.Decimal(10, 3)

  type        EntryType
  description String?   @db.Text

  // For Transfer logic
  toWalletId String?

  date      DateTime @default(now())
  createdAt DateTime @default(now())

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet   Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([walletId])
  @@index([categoryId])
}
