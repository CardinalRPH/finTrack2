// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id    String  @id @default(cuid())
  name  String?
  email String? @unique
  image String?

  // Relations to financial data
  accounts     Account[]
  sessions     Session[]
  wallets      Wallet[]
  categories   Category[]
  transactions Transaction[]
  createdAt    DateTime      @default(now())
  investments  Investment[]
}

// --- FINANCIAL MODELS ---

enum WalletType {
  CASH // Physical Wallet
  E_WALLET // QRIS, Gopay, OVO, Dana
  BANK // Savings, Debit, Credit Cards
}

model Wallet {
  id   String     @id @default(cuid())
  name String // e.g., "BCA Utama", "Gopay Pocket", "My Gold"
  type WalletType @default(CASH)

  // Use Decimal for money to avoid rounding issues (Rp millions can be large)
  balance Decimal @default(0) @db.Decimal(20, 2)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions      Transaction[] @relation("WalletFrom")
  receivedTransfers Transaction[] @relation("WalletTo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum EntryType {
  INCOME
  OUTCOME
  TRANSFER // Moving money between your own wallets (e.g., Bank -> QRIS)
}

model Category {
  id    String  @id @default(cuid())
  name  String // e.g., "Food", "Salary", "Investment"
  icon  String // e.g., "Utensils", "Wallet", "TrendingUp" (Lucide icon names)
  color String // Optional: hex code for UI branding (e.g., "#EF4444")

  userId String? // Optional: null for "System Default", or ID for "User Custom"
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  transactions Transaction[]

  @@unique([name, userId])
  @@index([userId])
}

model Transaction {
  id         String  @id @default(cuid())
  userId     String
  walletId   String
  categoryId String?

  type   EntryType
  amount Decimal   @db.Decimal(20, 2)

  // Khusus untuk transaksi emas
  isInvestment Boolean  @default(false)
  gramAmount   Decimal? @db.Decimal(10, 3)

  buyPrice  Decimal? @db.Decimal(20, 2) // Harga saat beli (per gram)
  sellPrice Decimal? @db.Decimal(20, 2) // Harga saat jual (per gram)

  description String?  @db.Text
  date        DateTime @default(now())

  // Logic Transfer: Jika type == TRANSFER, toWalletId harus diisi
  toWalletId String?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet   Wallet    @relation("WalletFrom", fields: [walletId], references: [id], onDelete: Cascade)
  toWallet Wallet?   @relation("WalletTo", fields: [toWalletId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([walletId])
  @@index([date])
}

model Investment {
  id          String  @id @default(cuid())
  userId      String  @unique
  assetName   String  @default("Gold")
  totalGrams  Decimal @default(0) @db.Decimal(10, 3)
  avgBuyPrice Decimal @default(0) @db.Decimal(20, 2) // Untuk hitung Profit/Loss

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}